{
    "name": "jobmetric/laravel-extension",
    "description": "This is a extension management package for Laravel that you can use in your projects.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "jobmetric",
        "package",
        "extension",
        "component",
        "plugin",
        "management"
    ],
    "homepage": "https://jobmetric.github.io/packages/laravel-extension",
    "authors": [
        {
            "name": "Majid Mohammadian",
            "email": "majeedmohammadian@gmail.com",
            "homepage": "https://www.linkedin.com/in/majidmohammadian/",
            "role": "Full Stack Developer"
        }
    ],
    "require": {
        "php": ">=8.0.1",
        "laravel/framework": ">=9.19",
        "jobmetric/laravel-package-core": "^1.38",
        "jobmetric/laravel-event-system": "^2.8",
        "jobmetric/laravel-form": "^1.6",
        "spatie/laravel-query-builder": "^6.3"
    },
    "autoload": {
        "files": [
            "src/helpers.php"
        ],
        "psr-4": {
            "JobMetric\\Extension\\": "src/",
            "JobMetric\\Extension\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JobMetric\\Extension\\ExtensionServiceProvider"
            ],
            "aliases": {
                "Extension": "JobMetric\\Extension\\Facades\\Extension",
                "Plugin": "JobMetric\\Extension\\Facades\\Plugin",
                "ExtensionNamespaceRegistry": "JobMetric\\Extension\\Facades\\ExtensionNamespaceRegistry",
                "ExtensionTypeRegistry": "JobMetric\\Extension\\Facades\\ExtensionTypeRegistry",
                "ExtensionRegistry": "JobMetric\\Extension\\Facades\\ExtensionRegistry",
                "InstalledExtensionsFile": "JobMetric\\Extension\\Facades\\InstalledExtensionsFile"
            }
        }
    },
    "minimum-stability": "stable",
    "support": {
        "issues": "https://github.com/jobmetric/laravel-extension/issues",
        "forum": "https://twitter.com/jobmetric",
        "source": "https://github.com/jobmetric/laravel-extension"
    }
}
